# Server and database
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://solbot:change-me@localhost:5432/solbot
WEBHOOK_SECRET=change-this-long-random-secret
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-this-password

# Market data
BIRDEYE_API_KEY=
BIRDEYE_BASE_URL=https://public-api.birdeye.so
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Live trading only. Use a paid Jupiter portal API key.
WALLET_PRIVATE_KEY=
JUPITER_API_KEY=
JUPITER_API_PLAN=paid
JUPITER_BASE_URL=https://api.jup.ag/swap/v2

# Strategy
BUY_AMOUNT_SOL=0.2
ADD_POSITION_ENABLED=true
ADD_POSITION_AMOUNT_SOL=0.2
ADD_POSITION_DROP_PERCENT=30
MAX_ADD_POSITION_COUNT=1
SLIPPAGE_PERCENT=6
MIN_FDV_USD=30000
MIN_LIQUIDITY_USD=10000
RSI_PERIOD=7
RSI_BUY_BELOW=30
RSI_SELL_CROSS_DOWN=70
RSI_SELL_ABOVE=80
MAX_SINGLE_CANDLE_DROP_PERCENT=3
LP_DROP_LOOKBACK_MINUTES=2
LP_DROP_THRESHOLD_PERCENT=10
TRAILING_ACTIVATE_PROFIT_PERCENT=20
TRAILING_DRAWDOWN_PERCENT=10
BATCH_SELL_DELAY_MS=3000
BATCH_SELL_FIRST_PERCENT=50

# Execution safety rails (not position or loss limits).
# 0 disables the fixed emergency stop loss.
EMERGENCY_STOP_LOSS_PERCENT=0
MAX_PRICE_IMPACT_PERCENT=8
MIN_WALLET_RESERVE_SOL=0.05
BLOCK_MINT_AUTHORITY=true
BLOCK_FREEZE_AUTHORITY=true
MARKET_STALE_AFTER_SECONDS=360
TRADING_PAUSED=false

MARKET_FILTER_INTERVAL_MS=180000
STRATEGY_INTERVAL_MS=30000
MARKET_REQUEST_CONCURRENCY=3
